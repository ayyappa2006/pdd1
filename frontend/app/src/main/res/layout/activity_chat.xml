<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f8fafc">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#0ba360" android:padding="16dp" android:orientation="horizontal" android:gravity="center_vertical">
        <ImageView android:id="@+id/ivBack" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_revert" android:tint="#ffffff"/>
        <TextView android:id="@+id/tvChatTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chat" android:textColor="#ffffff" android:textSize="20sp" android:textStyle="bold" android:layout_marginStart="16dp"/>
    </LinearLayout>
    <ListView android:id="@+id/lvMessages" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:divider="@null" android:dividerHeight="16dp" android:padding="16dp" android:clipToPadding="false" android:transcriptMode="alwaysScroll" android:stackFromBottom="true"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp" android:background="#ffffff" android:elevation="8dp">
        <EditText android:id="@+id/etMessage" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_rounded_white" android:hint="Type a message..." android:padding="16dp" android:layout_marginEnd="16dp"/>
        <ImageView android:id="@+id/btnSend" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_menu_send" android:background="@drawable/bg_rounded_button" android:backgroundTint="#0ba360" android:tint="#ffffff" android:padding="12dp"/>
    </LinearLayout>
</LinearLayout>
