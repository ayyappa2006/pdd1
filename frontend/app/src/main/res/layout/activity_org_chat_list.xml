<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f8fafc">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#0ba360" android:padding="16dp" android:orientation="horizontal" android:gravity="center_vertical">
        <ImageView android:id="@+id/ivBack" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_revert" android:tint="#ffffff"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inbox" android:textColor="#ffffff" android:textSize="20sp" android:textStyle="bold" android:layout_marginStart="16dp"/>
    </LinearLayout>
    <ListView android:id="@+id/lvChats" android:layout_width="match_parent" android:layout_height="match_parent" android:divider="@null" android:dividerHeight="16dp" android:padding="16dp" android:clipToPadding="false"/>
</LinearLayout>
